# Required in production — generate with: openssl rand -hex 32
JWT_SECRET=

# Port the server listens on (default: 3001)
PORT=3001

# Set to "production" to enable static file serving and disable dev CORS
NODE_ENV=development

# Optional: CORS origin in dev (default: http://localhost:5173)
CORS_ORIGIN=http://localhost:5173

# Optional: Override path to the built web frontend (default: ../../web/dist relative to server dist)
# WEB_DIST_PATH=/absolute/path/to/apps/web/dist
